---
// Real-time, no-backend, no-commenter-login comment section using Cusdis.
//
// SETUP (one time, ~60 seconds — admin only):
//   1. Go to https://cusdis.com and sign up with email (free, no credit card)
//   2. Click "New Site"
//      • Name: Stop Smart Meters Goa
//      • Domain: nosmartmetergoa.link
//   3. Copy the "App ID" shown on the dashboard
//   4. Paste it into CUSDIS_APP_ID below
//   5. Commit and push — comments work in real time forever after
//
// Once configured:
//   • Visitors just type Name + Comment and click Post — no login needed
//   • Comments appear instantly for everyone
//   • You moderate (approve/delete) from the Cusdis dashboard if you want
//   • Email notifications optional from the dashboard
//
// Until the App ID is filled in, the thread shows "comment section is being set up".

const CUSDIS_APP_ID = '';

interface Props {
  pageId: string;
}

const { pageId } = Astro.props;

// Build a stable canonical URL so comments stay attached even if the page
// is also reachable via www / github.io.
const canonicalUrl = `https://nosmartmetergoa.link/`;
const pageTitle = 'The Pros and Cons of Smart Meters — Stop Smart Meters Goa';
---

<section
  class="comments mt-12 sm:mt-16 pt-8 sm:pt-10 border-t border-gray-200 dark:border-gray-800"
  aria-label="Comments"
  data-page-id={pageId}
>
  <h2 class="text-2xl sm:text-3xl font-bold mb-2">Add your voice</h2>
  <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mb-6">
    No login required — just your name and your comment. Comments appear instantly.
  </p>

  {CUSDIS_APP_ID ? (
    <Fragment>
      <div
        id="cusdis_thread"
        data-host="https://cusdis.com"
        data-app-id={CUSDIS_APP_ID}
        data-page-id={pageId}
        data-page-url={canonicalUrl}
        data-page-title={pageTitle}
      ></div>
      <script is:inline async defer src="https://cusdis.com/js/cusdis.es.js"></script>
    </Fragment>
  ) : (
    <div class="p-5 sm:p-6 rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/40">
      <p class="text-sm text-gray-700 dark:text-gray-300">
        💬 Comments are being set up. They will be open for posting very shortly.
      </p>
      <p class="text-xs text-gray-500 dark:text-gray-500 mt-3">
        <em>Site admin: paste the Cusdis App ID in <code>src/components/Comments.astro</code> to activate this section. See setup instructions at the top of that file.</em>
      </p>
    </div>
  )}
</section>
